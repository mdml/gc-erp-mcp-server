# direnv shim for gc-erp-mcp-server.
# Auto-decrypts .envrc.enc (per-developer, gitignored) on cd into the repo.
# Regenerate .envrc.enc from 1Password with: turbo run sync-secrets

if ! command -v age >/dev/null 2>&1; then
  echo "direnv: 'age' not installed — run 'brew install age' (macOS) or 'apt-get install age' (Linux)" >&2
  return 1
fi

_gcerp_key="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"
_gcerp_enc="$(dirname "${BASH_SOURCE[0]:-$0}")/.envrc.enc"

if [ ! -f "$_gcerp_enc" ]; then
  echo "direnv: .envrc.enc not found — run 'turbo run sync-secrets' (see README: Deploy)" >&2
  unset _gcerp_key _gcerp_enc
  return 0
fi

if [ ! -f "$_gcerp_key" ]; then
  echo "direnv: age key not found at $_gcerp_key — run 'age-keygen -o \"$_gcerp_key\"' or set SOPS_AGE_KEY_FILE" >&2
  unset _gcerp_key _gcerp_enc
  return 1
fi

# Decrypt dotenv lines (KEY=value) and export them into the shell.
# `set -a` makes every assignment eval'd below into an exported variable.
set -a
# shellcheck disable=SC2046
eval "$(age -d -i "$_gcerp_key" "$_gcerp_enc" 2>/dev/null)" || {
  set +a
  echo "direnv: failed to decrypt .envrc.enc with $_gcerp_key" >&2
  unset _gcerp_key _gcerp_enc
  return 1
}
set +a

unset _gcerp_key _gcerp_enc
