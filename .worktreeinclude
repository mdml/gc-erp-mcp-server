# Files to copy from the main checkout into a `claude --worktree` worktree.
# Gitignore syntax; only matched-AND-gitignored files are copied.
# Docs: https://code.claude.com/docs/en/common-workflows#copy-gitignored-files-to-worktrees

# Encrypted team/dev env body. Re-rendering requires an active 1Password session,
# so copying it in is what makes `claude --worktree` work without manual setup.
.envrc.enc

# Wrangler local dev vars (matches packages/mcp-server/.dev.vars via gitignore semantics).
.dev.vars

# Personal 1Password refs — lets a dev optionally `eval $(op signin) && bun run sync-secrets`
# inside the worktree to refresh secrets without hand-copying refs.
.env.op.local

# Agent permission policy. `bun install`'s post-checkout bootstrap regenerates
# this from `packages/agent-config/src/policy/`, but Claude Code reads the file
# at session-start — racing the bootstrap. Copying it in eliminates the race so
# the first `git fetch` / `git checkout -b` in a fresh worktree auto-allows
# without prompting. Bootstrap re-renders it idempotently with the same content.
.claude/settings.json
