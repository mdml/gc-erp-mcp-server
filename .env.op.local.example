# Per-developer 1Password refs for personal secrets.
# Copy to .env.op.local and fill in the op:// references for any secrets
# you want `turbo run sync-secrets` to pull into /.envrc.enc.
#
# Leaving a value blank (or omitting the line) skips that secret during
# `sync-secrets`. Whether the downstream tool tolerates the absence varies
# per secret — see descriptions in packages/dev-tools/src/secrets.config.ts.
# (Heads-up: CS_ACCESS_TOKEN is required to commit/push — see the README.)

CS_ACCESS_TOKEN=
GH_TOKEN=
