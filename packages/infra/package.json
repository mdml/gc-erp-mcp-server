{
  "name": "@gc-erp/infra",
  "private": true,
  "type": "module",
  "scripts": {
    "infra:status": "bun run src/status.ts",
    "infra:apply": "bun run src/apply.ts",
    "infra:teardown": "bun run src/teardown.ts",
    "lint": "biome check .",
    "format": "biome check --write --unsafe .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "jsonc-parser": "^2.3.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@vitest/coverage-v8": "4.1.4",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
