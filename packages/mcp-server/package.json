{
  "name": "@gc-erp/mcp-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:remote": "wrangler d1 migrations apply gc-erp --remote",
    "lint": "biome check .",
    "format": "biome check --write --unsafe .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "@gc-erp/database": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "agents": "0.11.0",
    "drizzle-orm": "0.45.2",
    "stytch": "14.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260415.1",
    "@types/better-sqlite3": "7.6.13",
    "@vitest/coverage-v8": "4.1.4",
    "better-sqlite3": "12.8.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4",
    "wrangler": "4.83.0"
  }
}
