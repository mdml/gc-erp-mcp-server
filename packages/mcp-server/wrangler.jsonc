{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "gc-erp-mcp-server",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-15",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [{ "name": "MCP_OBJECT", "class_name": "GcErpMcp" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["GcErpMcp"] }]
}
