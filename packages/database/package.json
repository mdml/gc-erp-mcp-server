{
  "name": "@gc-erp/database",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./ids": "./src/ids/index.ts",
    "./invariants": "./src/invariants/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write --unsafe .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:seed:activities": "bun run src/seed/run.ts activities"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "nanoid": "5.1.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260415.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/bun": "1.3.11",
    "@vitest/coverage-v8": "4.1.4",
    "better-sqlite3": "12.8.0",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
