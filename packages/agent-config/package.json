{
  "name": "@gc-erp/agent-config",
  "private": true,
  "type": "module",
  "scripts": {
    "install-agent-config": "bun run src/install.ts",
    "bootstrap": "bun run src/bootstrap.ts",
    "lint": "biome check .",
