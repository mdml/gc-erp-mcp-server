{
  "name": "@gc-erp/dev-tools",
  "private": true,
  "type": "module",
  "scripts": {
    "gate": "bun run src/gate.ts",
    "scenario": "bun run src/scenarios/run.ts",
    "scenario:reset": "bun run src/scenarios/reset-cli.ts",
    "db:migrate:local": "bun run src/db/migrate.ts local",
    "db:migrate:prod": "bun run src/db/migrate.ts prod",
    "db:seed:activities:local": "bun run src/db/seed-activities.ts local",
    "db:seed:activities:prod": "bun run src/db/seed-activities.ts prod",
    "db:query:local": "bun run src/db/query.ts local",
    "db:query:prod": "bun run src/db/query.ts prod",
    "db:reset:local": "bun run src/db/reset.ts",
    "install:mcp:local": "bun run src/install-mcp/install-local.ts",
    "install:mcp:prod": "bun run src/install-mcp/install-prod.ts",
    "lint": "biome check .",
    "format": "biome check --write --unsafe .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@gc-erp/database": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@vitest/coverage-v8": "4.1.4",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
