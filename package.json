{
  "name": "gc-erp-mcp-server",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "if [ -d .git ]; then lefthook install --reset-hooks-path; fi && bun run --cwd packages/agent-config install-agent-config",
    "dev": "turbo run dev --filter=@gc-erp/mcp-server",
    "deploy": "turbo run deploy --filter=@gc-erp/mcp-server",
    "tail": "turbo run tail --filter=@gc-erp/mcp-server",
    "lint": "turbo run lint",
    "format": "biome check --write --unsafe .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "gate": "bun run --cwd packages/dev-tools gate",
    "code-health": "bun run --cwd packages/dev-tools code-health",
    "sync-secrets": "turbo run sync-secrets --filter=@gc-erp/dev-tools",
    "seed:kitchen-fixture": "bun run --cwd packages/database db:seed:kitchen-fixture",
    "db:migrate:remote": "bun run --cwd packages/mcp-server db:migrate:remote",
    "install-agent-config": "turbo run install-agent-config --filter=@gc-erp/agent-config",
    "infra:status": "bun run --cwd packages/infra infra:status",
    "infra:apply": "bun run --cwd packages/infra infra:apply",
    "infra:teardown": "bun run --cwd packages/infra infra:teardown"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "lefthook": "2.1.5",
    "turbo": "^2.0.0"
  }
}
