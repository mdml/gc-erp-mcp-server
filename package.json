{
  "name": "gc-erp-mcp-server",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "if [ -d .git ]; then lefthook install --reset-hooks-path; fi && bun run --cwd packages/agent-config install-agent-config",
    "dev": "turbo run dev --filter=@gc-erp/mcp-server",
    "deploy": "turbo run deploy --filter=@gc-erp/mcp-server",
    "tail": "turbo run tail --filter=@gc-erp/mcp-server",
    "lint": "turbo run lint",
    "format": "biome check --write --unsafe .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "gate": "bun run --cwd packages/dev-tools gate",
    "code-health": "bash scripts/codescene.sh gate-all",
    "scenario": "bun run --cwd packages/dev-tools scenario",
    "scenario:reset": "bun run --cwd packages/dev-tools scenario:reset",
    "db:migrate:local": "bun run --cwd packages/dev-tools db:migrate:local",
    "db:migrate:prod": "bun run --cwd packages/dev-tools db:migrate:prod",
    "db:seed:activities:local": "bun run --cwd packages/dev-tools db:seed:activities:local",
    "db:seed:activities:prod": "bun run --cwd packages/dev-tools db:seed:activities:prod",
    "db:seed:kitchen:local": "bun run --cwd packages/database db:seed:kitchen:local",
    "db:query:local": "bun run --cwd packages/dev-tools db:query:local",
    "db:query:prod": "bun run --cwd packages/dev-tools db:query:prod",
    "db:reset:local": "bun run --cwd packages/dev-tools db:reset:local",
    "install:mcp:local": "bun run --cwd packages/dev-tools install:mcp:local",
    "install:mcp:prod": "bun run --cwd packages/dev-tools install:mcp:prod",
    "install-agent-config": "turbo run install-agent-config --filter=@gc-erp/agent-config",
    "infra:status": "bun run --cwd packages/infra infra:status",
    "infra:apply": "bun run --cwd packages/infra infra:apply",
    "infra:teardown": "bun run --cwd packages/infra infra:teardown"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@dotenvx/dotenvx": "1.61.1",
    "lefthook": "2.1.5",
    "turbo": "^2.0.0"
  }
}
