{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["biome.json"],
  // Env vars passed to every task's child process. Turbo 2.x scrubs env by
  // default; without this list, wrangler/op see no creds and fall back to
  // OAuth (which in turn silently uses cached state bound to the wrong CF
  // account). Use globalPassThroughEnv (not globalEnv) — pass-through vars
  // are not hashed into the task cache key, so secrets stay out of cache
  // metadata.
  "globalPassThroughEnv": [
    "CLOUDFLARE_API_TOKEN",
    "CLOUDFLARE_ACCOUNT_ID",
    "CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "OP_SERVICE_ACCOUNT_TOKEN"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "deploy": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "tail": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      // Depends on upstream builds because apps/mcp-server imports
      // @gc-erp/cost-entry-form/dist/cost-entry-form.html at typecheck time —
      // the file must exist or tsc can't resolve the module, even with the
      // Text-loader @ts-expect-error at the import site.
      "dependsOn": ["^build"]
    },
    "build": {
      "inputs": ["src/**", "vite.config.ts", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "vitest.config.ts", "package.json", "tsconfig.json"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "vitest.config.ts", "package.json", "tsconfig.json"],
      "outputs": ["coverage/**"]
    },
    "sync-secrets": {
      "cache": false
    },
    "install-agent-config": {
      "cache": false
    }
  }
}
