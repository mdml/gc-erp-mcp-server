{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["biome.json"],
  // Env vars passed to every task's child process. Turbo 2.x scrubs env by
  // default; without this list, wrangler/op see no creds and fall back to
  // OAuth (which in turn silently uses cached state bound to the wrong CF
  // account). Use globalPassThroughEnv (not globalEnv) — pass-through vars
  // are not hashed into the task cache key, so secrets stay out of cache
  // metadata.
  "globalPassThroughEnv": [
    "CLOUDFLARE_API_TOKEN",
    "CLOUDFLARE_ACCOUNT_ID",
    "OP_SERVICE_ACCOUNT_TOKEN",
    "STYTCH_PROJECT_ID",
    "STYTCH_SECRET"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "cache": false
    },
    "tail": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {},
    "test": {
      "inputs": ["src/**", "vitest.config.ts", "package.json", "tsconfig.json"]
    },
    "test:coverage": {
      "inputs": ["src/**", "vitest.config.ts", "package.json", "tsconfig.json"],
      "outputs": ["coverage/**"]
    },
    "sync-secrets": {
      "cache": false
    },
    "install-agent-config": {
      "cache": false
    }
  }
}
