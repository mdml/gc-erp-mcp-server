{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["biome.json"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "cache": false
    },
    "tail": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {},
    "test": {
      "inputs": ["src/**", "vitest.config.ts", "package.json", "tsconfig.json"]
    },
    "test:coverage": {
      "inputs": ["src/**", "vitest.config.ts", "package.json", "tsconfig.json"],
      "outputs": ["coverage/**"]
    },
    "sync-secrets": {
      "cache": false
    },
    "install-agent-config": {
      "cache": false
    }
  }
}
